{
  "name": "highlighter-snowshot",
  "version": "2.0.0",
  "description": "Highlighter - 截图、标注、OCR、翻译与 AI 桌面效率工具",
  "main": "main.js",
  "author": "Highlighter",
  "scripts": {
    "build:smart-select": "powershell -NoProfile -ExecutionPolicy Bypass -File native/smart-select/build.ps1",
    "prestart": "npm run build:smart-select",
    "start": "electron .",
    "prebuild:win": "npm run build:smart-select",
    "build:win": "electron-builder --win --x64",
    "prebuild:win:portable": "npm run build:smart-select",
    "build:win:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.highlighter.desktop",
    "productName": "Highlighter",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/screenshot-desktop/lib/win32/**/*"
    ],
    "extraResources": [
      {
        "from": "native/smart-select/SmartSelect.exe",
        "to": "native/smart-select/SmartSelect.exe"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "preload-toolbar.js",
      "preload-capture.js",
      "preload-pin.js",
      "preload-record.js",
      "deepseek.js",
      "assets/**/*",
      "config/**/*",
      "toolbar/**/*",
      "action/**/*",
      "capture/**/*",
      "pin/**/*",
      "record/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Highlighter"
    },
    "portable": {
      "artifactName": "Highlighter-${version}-portable.exe"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "jsqr": "^1.4.0",
    "openai": "^4.87.3",
    "screenshot-desktop": "^1.15.4",
    "selection-hook": "^2.0.2",
    "showdown": "^2.1.0",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.0.12"
  },
  "allowScripts": {
    "electron": true,
    "selection-hook": true,
    "@electron/rebuild": true,
    "electron-builder": true
  }
}
